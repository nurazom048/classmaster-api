#################################
# 🌐 ENVIRONMENT & MODES
#################################
# Set to 'development' for local testing (uses DEV_DATABASE_URL and local configurations)
# Set to 'production' for live server environment (uses PROD_DATABASE_URL/DATABASE_URL)
NODE_ENV=development

#################################
# 🔐 AUTH / SECURITY
#################################
JWT_SECRET_KEY=
REFRESH_TOKEN_SECRET=

#################################
# 🗄️ DATABASES
#################################
# PostgreSQL (Dynamic Connection)
DATABASE_URL="postgresql://postgres:1234@localhost:5432/classmaster?schema=public"
DEV_DATABASE_URL="postgresql://postgres:1234@db:5432/classmaster?schema=public"
PROD_DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_PRISMA_POSTGRES_API_KEY"



#################################
# 📦 STORAGE SETTINGS
#################################
# Active storage provider: 'minio' or 'r2'
STORAGE_PROVIDER=r2

# Storage Bucket Name
BUCKET_NAME=strogeforclassmaster

# --- 💻 DEVELOPMENT (MinIO) ---
MINIO_ENDPOINT=http://local-minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# --- 🚀 PRODUCTION (Cloudflare R2) ---
R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- 🚀 APPWRITE STORAGE ---
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_BUCKET_ID=

#################################
# 🔑 API KEYS (External Services)
#################################
api_key=
PULSE_API_KEY=

#################################
# 🤖 TELEGRAM BOT
#################################
# Telegram Bot Token (From @BotFather)
TELEGRAM_BOT_TOKEN=
# Your Telegram Chat ID (From @userinfobot)
TELEGRAM_CHAT_ID=
