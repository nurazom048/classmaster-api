#################################
# 🌐 ENVIRONMENT & MODES
#################################
NODE_ENV=development

#################################
# 🔐 AUTH / SECURITY
#################################
JWT_SECRET_KEY=
REFRESH_TOKEN_SECRET=

#################################
# 🗄️ DATABASES
#################################
# PostgreSQL (Dynamic Connection)
DATABASE_URL="postgresql://postgres:1234@localhost:5432/classmaster?schema=public"
DEV_DATABASE_URL="postgresql://postgres:1234@db:5432/classmaster?schema=public"
PROD_DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_PRISMA_POSTGRES_API_KEY"

# MongoDB (Other temporary databases)
MONGODB_URI_MAIN_DB=
MONGODB_URI_NOTIFICATION_DB=

#################################
# 📦 CLOUD STORAGE SETTINGS
#################################
# Set storage provider: 'minio' or 'appwrite'
STORAGE_PROVIDER=minio

# MinIO Storage Credentials (used when STORAGE_PROVIDER=minio)
MINIO_ENDPOINT=http://local-minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=storageforclassmaster
MINIO_EXTERNAL_URL=http://localhost:9000

# Appwrite Storage Credentials (used when STORAGE_PROVIDER=appwrite)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_BUCKET_ID=
APPWRITE_API_KEY=

#################################
# 🔑 API KEYS (External Services)
#################################
api_key=
PULSE_API_KEY=

#################################
# 🤖 TELEGRAM BOT
#################################
# Telegram Bot Token (From @BotFather)
TELEGRAM_BOT_TOKEN=
# Your Telegram Chat ID (From @userinfobot)
TELEGRAM_CHAT_ID=
